{
    "name": "template",
    "version": "1.0.0",
    "description": "A template to generate well-configured project base for Stegripe.",
    "license": "CC-BY-NC-ND-4.0",
    "author": "Stegripe Development <support@stegripe.org>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/stegripe/template.git"
    },
    "bugs": {
        "url": "https://github.com/stegripe/template/issues"
    },
    "homepage": "https://github.com/stegripe/template#readme",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "pnpm lint && rimraf dist && tsc --build tsconfig.json",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "start": "node .",
        "dev": "pnpm build && pnpm start"
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=7.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@stegripe/biomejs-config": "^1.1.0",
        "@types/node": "^24.12.3",
        "rimraf": "^6.1.3",
        "typescript": "^6.0.3"
    }
}
